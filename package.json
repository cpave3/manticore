{
  "name": "manticore",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "bin": {
    "manticore": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && (cd dashboard && vite build)",
    "dashboard:dev": "vite --config dashboard/vite.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-validator": "^0.8.0",
    "@huggingface/transformers": "^4.2.0",
    "@nivo/calendar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "ai": "^6.0.184",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.39.3",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.19",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^3.0.0"
  }
}
